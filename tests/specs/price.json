[
  {
    "name": "/price with empty watchlist shows empty state",
    "steps": [
      {
        "send": { "text": "/price" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "Your watchlist is empty — add a coin first, or try /price BTC."
            }
          }
        ]
      }
    ]
  },
  {
    "name": "/price with invalid blank-ish ticker",
    "steps": [
      {
        "send": { "text": "/price x" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": {
              "text": "That doesn't look like a ticker. Try /price BTC."
            }
          }
        ]
      }
    ]
  }
]
